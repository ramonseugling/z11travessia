---
<section id="video" class="bg-alt">
  <div class="container container--narrow" style="text-align:center">
    <div class="sect-label reveal" style="justify-content:center">Em Movimento</div>
    <h2 class="reveal reveal-d1" style="font-family:var(--serif);font-weight:300;font-size:clamp(1.8rem,3.5vw,2.8rem);line-height:1.15;margin:16px 0 8px">A travessia em vídeo</h2>
    <p class="reveal reveal-d2" style="font-family:var(--serif);font-style:italic;font-size:clamp(1rem,1.8vw,1.15rem);color:var(--text-dim)">Dois minutos para sentir o que palavras não alcançam</p>
    <div class="video-wrapper reveal reveal-d3">
      <!-- Substituir pelo embed real: <iframe src="https://www.youtube.com/embed/SEU_VIDEO_ID" allowfullscreen></iframe> -->
      <div class="video-placeholder">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <polygon points="10 8 16 12 10 16 10 8" fill="currentColor" stroke="none"></polygon>
        </svg>
        <p>Vídeo em breve</p>
      </div>
    </div>
  </div>
</section>

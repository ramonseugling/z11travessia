<section id="gallery" class="bg-alt">
  <div class="container">
    <div class="sect-label reveal">Galeria</div>
    <h2 class="reveal reveal-d1" style="font-family:var(--serif);font-weight:300;font-size:clamp(2rem,4vw,3.2rem);line-height:1.15;margin:16px 0 8px">Momentos no mar</h2>
    <p class="reveal reveal-d2" style="font-family:var(--serif);font-style:italic;font-size:clamp(1rem,1.8vw,1.2rem);color:var(--text-dim)">Cada expedição é uma nova história</p>
  </div>
  <div class="gallery-track reveal reveal-d3">
    {images.map((img) => (
      <img src={img.src} alt={img.alt} loading="lazy">
    ))}
  </div>
  <p class="gallery-hint reveal">← arraste para ver mais</p>
</section>

---
---
<section class="hero" id="hero">
  <img
    src="/assets/dfbcffca-89b4-4e89-86c5-d9e563a9594d.jpg"
    alt="Barco Travessia no mar do sul de Florianópolis"
    class="hero-media-bg"
    loading="eager"
    fetchpriority="high"
  >
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <p class="eyebrow hero-eyebrow reveal">z11 travessia · mar e gastronomia</p>
    <h1 class="reveal reveal-d1">O Sul da Ilha<br>pelo Mar</h1>
    <p class="hero-sub reveal reveal-d2">Uma travessia pelos mares do sul de Florianópolis</p>
    <p class="hero-body reveal reveal-d3">Expedições, gastronomia e natureza preservada.</p>
    <div class="hero-ctas reveal reveal-d4">
      <a href="https://wa.me/5548900000000?text=Olá! Gostaria de reservar uma expedição." class="btn btn--gold" target="_blank" rel="noopener">
        Reserve sua expedição
      </a>
      <a href="#expeditions" class="btn btn--outline">Conheça as rotas</a>
    </div>
  </div>
  <div class="hero-scroll"></div>
  <div class="hero-wave">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" fill="none">
      <path d="M0 40C240 10 480 55 720 35C960 15 1200 50 1440 30V60H0Z" fill="var(--bg-alt)"></path>
    </svg>
  </div>
</section>
